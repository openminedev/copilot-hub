{
  "name": "@copilot-hub/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Versioned contracts between control-plane and agent-engine",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && tsc -p tsconfig.test.json && node --test test-dist/**/*.test.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./control-plane": {
      "types": "./dist/control-plane.d.ts",
      "import": "./dist/control-plane.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "control-plane.v1.json"
  ]
}
