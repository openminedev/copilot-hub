{
  "name": "@copilot-hub/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared core utilities for Copilot Hub",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test"
